<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.2.xsd">

  <form id="supplychain-freight-carrier-mode-form" name="freight-carrier-mode-form"
    title="Freight carrier mode" model="com.axelor.apps.stock.db.FreightCarrierMode"
    extension="true">

    <extend target="//panel[@name='mainPanel']">
      <insert position="after">
        <panel-related field="freightCarrierPricingSet"
          form-view="freight-carrier-pricings-grid" grid-view="freight-carrier-pricings-grid"
          colSpan="12" canSelect="true"/>
      </insert>
    </extend>
  </form>

  <form id="supplychain-freight-carrier-mode-shipment-mode-form"
    name="freight-carrier-mode-shipment-mode-form" title="Freight carrier mode"
    model="com.axelor.apps.stock.db.FreightCarrierMode" extension="true">

    <extend target="//panel[@name='mainPanel']">
      <insert position="after">
        <panel name="carrierPricingPanel" title="Carrier pricings" colSpan="12">
          <field name="carrierPricingSet" colSpan="12" canSelect="true"/>
        </panel>
      </insert>
    </extend>
  </form>

  <form id="supplychain-freight-carrier-mode-freight-carrier-form"
    name="freight-carrier-mode-freight-carrier-form" title="Freight carrier mode"
    model="com.axelor.apps.stock.db.FreightCarrierMode" extension="true">

    <extend target="//panel[@name='mainPanel']">
      <insert position="after">
        <panel name="carrierPricingPanel" title="Carrier pricings" colSpan="12">
          <field name="carrierPricingSet" colSpan="12" canSelect="true"/>
        </panel>
      </insert>
    </extend>
  </form>

</object-views>
