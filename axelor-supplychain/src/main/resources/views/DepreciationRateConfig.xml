<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views https://axelor.com/xml/ns/object-views/object-views_8.2.xsd">

  <grid name="depreciation-rate-config-grid" title="Depreciation rate configurations"
    model="com.axelor.apps.supplychain.db.DepreciationRateConfig" editable="true">
    <field name="typeSelect" widget="ImageSelect">
      <hilite if="typeSelect == 1" color="danger"/>
      <hilite if="typeSelect == 2" color="success"/>
    </field>
    <field name="product" domain="self.stockManaged IS TRUE"/>
    <field name="productCategory"/>
    <field name="productFamily"/>
    <field name="stockRotationCategory" widget="Tag" x-color-field="color"/>
    <field name="minRate" x-scale="2"/>
    <field name="maxRate" x-scale="2"/>
    <field name="defaultRate" x-scale="2"/>
  </grid>

  <form name="depreciation-rate-config-form" title="Depreciation rate configuration"
    model="com.axelor.apps.supplychain.db.DepreciationRateConfig" width="large">
    <panel name="mainPanel" title="Configuration">
      <panel name="typePanel" colSpan="12">
        <field name="typeSelect" widget="ImageSelect" required="true" colSpan="12">
          <viewer depends="typeSelect"><![CDATA[
            <>
              <Box color={typeSelect == 1 ? 'danger' : 'success'} d="flex" alignItems="center">
                <Icon icon={typeSelect == 1 ? 'graph-down-arrow' : 'graph-up-arrow'}/>
                <span style={{marginLeft: '6px'}}>{$fmt('typeSelect')}</span>
              </Box>
            </>
          ]]></viewer>
        </field>
      </panel>
      <panel name="levelPanel" colSpan="12" title="Configuration Level"
        help="Set one or more dimensions (product, product category, product family, stock rotation category). The configuration applies to a product only if it matches all the dimensions set on the line.">
        <field name="product" grid-view="product-grid" form-view="product-form" colSpan="12"
          domain="self.stockManaged IS TRUE"/>
        <field name="productCategory" grid-view="product-category-grid"
          form-view="product-category-form" colSpan="12"/>
        <field name="productFamily" colSpan="12"/>
        <field name="stockRotationCategory" widget="Tag" x-color-field="color"
          grid-view="stock-rotation-category-grid" form-view="stock-rotation-category-form"
          colSpan="12"/>
      </panel>
      <panel name="ratesPanel" colSpan="12" title="Rates">
        <field name="minRate" colSpan="4"
          help="Minimum acceptable rate. Values below this will be flagged."/>
        <field name="maxRate" colSpan="4"
          help="Maximum acceptable rate. Values above this will be flagged."/>
        <field name="defaultRate" colSpan="4"
          help="Default rate to apply when calculation runs"/>
      </panel>
    </panel>
  </form>

</object-views>
