<?xml version="1.0" encoding="UTF-8"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_8.2.xsd">

  <grid name="loan-management-config-grid" title="Loan configurations"
    model="com.axelor.apps.account.db.LoanManagementConfig">
    <field name="name"/>
    <field name="company"/>
    <field name="journal"/>
    <field name="sequence"/>
  </grid>

  <form name="loan-management-config-form" title="Loan configuration"
    model="com.axelor.apps.account.db.LoanManagementConfig">
    <panel name="mainPanel" title="Configuration">
      <field name="name"/>
      <field name="company"/>
      <field name="journal"/>
      <field name="sequence"/>
    </panel>
    <panel name="conditionsPanel" title="Default conditions">
      <field name="annualInterestRate"/>
      <field name="computationModeSelect"/>
      <field name="durationInMonth"/>
      <field name="monthlyInsuranceAmount"/>
    </panel>
    <panel name="accountsPanel" title="Accounts">
      <field name="borrowingDebtAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect = 'debt'"/>
      <field name="interestExpenseAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect = 'charge'"/>
      <field name="insuranceExpenseAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect = 'charge'"/>
      <field name="bankAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect = 'cash'"/>
      <field name="accruedInterestAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect = 'debt'"/>
      <field name="prepaidExpenseAccount"
        domain="self.statusSelect = 1 AND self.company = :company AND self.accountType.technicalTypeSelect != 'view'"/>
    </panel>
  </form>

</object-views>
