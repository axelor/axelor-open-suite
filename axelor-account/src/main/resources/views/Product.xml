<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_8.0.xsd">

  <form id="account-product-form" title="Product" name="product-form"
    model="com.axelor.apps.base.db.Product" extension="true">
    <extend target="//field[@name='usedInDEB']">
      <insert position="after">
        <field name="defaultEcoTaxAmount" colSpan="2" showIf="productTypeSelect != 'service'"/>
        <field name="defaultEcoTaxMention" showIf="productTypeSelect != 'service'"
          colSpan="10"/>
      </insert>
    </extend>
  </form>

</object-views>