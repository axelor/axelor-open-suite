<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_8.0.xsd">

  <form name="bank-details-form" id="account-bank-details-form" title="Bank details"
    model="com.axelor.apps.base.db.BankDetails" extension="true">
    <extend target="//field[@name='specificNoteOnInvoice']">
      <insert position="before">
        <field name="invoiceNoteType" colSpan="6" requiredIf="specificNoteOnInvoice"/>
      </insert>
    </extend>
  </form>

</object-views>
