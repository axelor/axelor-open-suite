<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_8.1.xsd">

  <grid name="vat-exemption-reason-grid" title="VAT exemption reasons"
    model="com.axelor.apps.account.db.VatExemptionReason" orderBy="code">
    <field name="code"/>
    <field name="name"/>
  </grid>

  <form name="vat-exemption-reason-form" title="VAT exemption reason"
    model="com.axelor.apps.account.db.VatExemptionReason" width="large">
    <panel name="mainPanel">
      <field name="code"/>
      <field name="name"/>
      <field name="note" colSpan="12"/>
    </panel>
    <panel-mail>
      <mail-messages limit="4"/>
      <mail-followers/>
    </panel-mail>
  </form>

</object-views>
