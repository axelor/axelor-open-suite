<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models http://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

  <module name="account" package="com.axelor.apps.account.db"/>

  <entity name="VatExemptionReason" cacheable="true">

    <string name="code" title="Code" required="true" unique="true" namecolumn="true"/>
    <string name="name" title="Name" required="true"/>
    <string name="note" title="Note" large="true"/>

    <track>
      <field name="code"/>
      <field name="name"/>
      <field name="note"/>
    </track>

  </entity>

</domain-models>
