<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models http://axelor.com/xml/ns/domain-models/domain-models_7.4.xsd">

  <module name="studio" package="com.axelor.studio.db"/>

  <entity name="AppProject" cacheable="true">

    <many-to-one name="completedPaidProjectStatus" title="Completed paid project status"
      ref="com.axelor.apps.project.db.ProjectStatus"/>
    <many-to-one name="defaultProjectType" title="Default project type"
      ref="com.axelor.apps.businessproject.db.ProjectType"/>

    <boolean name="manageStatusAutomatically" title="Enable automatic status change"
      help="When enabled project and task statuses will be updated automatically" default="false"/>

    <track>
      <field name="completedPaidProjectStatus" on="UPDATE"/>
      <field name="defaultProjectType" on="UPDATE"/>
      <field name="manageStatusAutomatically" on="UPDATE"/>
    </track>
  </entity>

</domain-models>
