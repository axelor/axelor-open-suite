            <xml-property name="queryText"><![CDATA[SELECT
  tmr.id                    AS member_report_id,

  u.full_name               AS employee_name,

  pt.name                   AS task_name,
  cat.name                  AS task_category,

  tmr.start_time,
  tmr.end_time,
  tmr.break_time_minutes,
  tmr.work_hours

FROM businessproject_task_member_report tmr

LEFT JOIN auth_user u
       ON u.id = tmr.employee

LEFT JOIN project_project_task pt
       ON pt.id = tmr.task

LEFT JOIN project_project_task_category cat
       ON cat.id = tmr.task_category

WHERE tmr.task_report = ?
ORDER BY tmr.start_time]]></xml-property>
        </oda-data-set>
