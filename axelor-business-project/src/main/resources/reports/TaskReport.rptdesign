                                    <structure name="toc"/>
                                    <method name="onCreate"><![CDATA[java.lang.System.out.println("Start- BIRT Template employee signature decoding logs");

try {
    var blobData = row["employee_signature_blob"];
    
    if (blobData != null) {
        var wrappedString = new java.lang.String(blobData, "UTF-8");
        
        var base64Only = wrappedString;
        if (base64Only.contains(",")) {

            base64Only = base64Only.substring(base64Only.indexOf(",") + 1);
        }
        
        base64Only = base64Only.replaceAll("\\s", "");
        
        this.data = java.util.Base64.getDecoder().decode(base64Only);
        
        java.lang.System.out.println("LOG From BIRT Template: Successfully decoded. Byte length: " + this.data.length);
    }
    
} catch (e) {
    java.lang.System.out.println("LOG From BIRT Template: Conversion failed:) " + e);
    this.data = null;
}

java.lang.System.out.println("End- BIRT Template employee signature decoding logs");
]]></method>
