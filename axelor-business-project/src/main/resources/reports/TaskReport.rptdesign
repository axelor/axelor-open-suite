            <xml-property name="queryText"><![CDATA[SELECT
  tr.id                              AS task_report_id,
  tr.task_date                       AS task_date,
  p.name                             AS project_name,
  partner.simple_full_name           AS partner_name,
  tr.customer_not_available          AS customer_not_available,
  addr.full_name                     AS location_name,
  emp.full_name						 AS employee_name,
  tr.customer_name					 AS customer_name,
  tr.total_work_hours                AS total_work_hours,
  tr.travel_expenses                 AS travel_expenses,
  tr.tools_usage                     AS tools_usage,
  tr.dirt_allowance                  AS dirt_allowance,
  tr.reported_all_tasks              AS reported_all_tasks,
  tr.material                        AS material,
  tr.comments                        AS comments,
  tr.employee_signature              AS employee_signature,
  tr.customer_signature              AS customer_signature

FROM businessproject_task_report tr
LEFT JOIN project_project p
       ON p.id = tr.project
LEFT JOIN base_partner partner
       ON partner.id = tr.customer
LEFT JOIN base_address addr
       ON addr.id = tr.location
LEFT JOIN auth_user emp
       ON emp.id = tr.employee
WHERE tr.id = ?]]></xml-property>
        </oda-data-set>
