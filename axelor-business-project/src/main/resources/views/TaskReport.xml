<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.4.xsd">

  <!-- Grid View -->
  <grid name="task-report-grid" title="Task Reports"
    model="com.axelor.apps.businessproject.db.TaskReport" canEdit="true" canNew="false"
    canArchive="true" canDelete="true" onNew="action-business-project-add-task-report">
    <field name="project" title="Order" canView="true"/>
    <field name="customer.simpleFullName" title="Customer" canView="true"/>
    <field name="taskDate" title="Date"/>
    <field name="location" canView="true"/>
    <field name="totalWorkHours"/>
  </grid>

  <grid name="add-task-report-grid" title="Task Reports" canDelete="true" canNew="false"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <field name="project" title="Order "/>
    <field name="customer.simpleFullName" title="Customer"/>
    <field name="taskDate" title="Date"/>
    <field name="location"/>
    <field name="totalWorkHours"/>
  </grid>

  <!-- Grid View for TaskMemberReport -->
  <grid name="task-member-report-grid" title="Team Members' Reports" canDelete="true"
    canEdit="true" canNew="false" model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="employee" title="Employee"/>
    <field name="task" title="Task"/>
    <field name="taskCategory" title="Task Category"/>
    <field name="startTime" title="Start Time"/>
    <field name="breakTimeMinutes" title="Break Time (min)"/>
    <field name="endTime" title="End Time"/>
    <field name="workHours" title="Work Hours (hours)"/>
    <field name="breakTimeHours" title="Break Time (hours)" hidden="true"/>
    <field name="dirtAllowance" widget="checkbox"/>
  </grid>

  <grid name="task-member-report-review-grid" title="Team Members' Reports Review"
    canDelete="false" canEdit="false" canNew="false"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="employee" title="Employee"/>
    <field name="task" title="Task"/>
    <field name="taskCategory" title="Task Category"/>
    <field name="task.product"/>
    <field name="startTime" title="Start Time"/>
    <field name="breakTimeMinutes" title="Break Time (min)"/>
    <field name="endTime" title="End Time"/>
    <field name="workHours" title="Work Hours (hours)"/>
    <field name="breakTimeHours" title="Break Time (hours)" hidden="true"/>
    <field name="dirtAllowance" widget="checkbox"/>
  </grid>

  <!-- Form View -->
  <form name="task-report-form" title="Task Reports" canEdit="true" canAttach="false"
    model="com.axelor.apps.businessproject.db.TaskReport"
    onNew="action-task-report-default, action-task-report-attrs-filter-projects"
    onLoad="action-task-report-group-on-load" onSave="action-task-report-group-on-save"
    width="large">
    <toolbar>
      <button name="projectFilesBtn" title="Project Files" icon="fa-paperclip"
        showIf="project != null" onClick="action-method-project-find-project-files"/>
    </toolbar>
    <panel colSpan="12" name="taskReportMainPanel">
      <panel colSpan="12" name="parentPanel" showFrame="true">
        <panel-include view="task-report-header-form"/>
        <panel title="General Information" showFrame="false">
          <field name="project" title="Order" canView="false"
            domain-function="eval: ( (__user__.group.code == 'CUSTOM-PM' || __user__.group.code == 'CUSTOM-OM')
                    ? 'self.projectStatus.isCompleted = false'
                    : 'self.projectStatus.isCompleted = false AND (self.membersUserSet.id = :__user__ OR self.assignedTo.id = :__user__)' )"
            onChange="action-task-report-on-change-project" required="true"/>
          <field name="customer" hidden="true"/>
          <field name="customer" readonly="true" canView="false"/>
          <field name="location" readonly="true" canView="false"/>
          <field name="$tslDeleteWarningState" readonly="true" hidden="true"/>
        </panel>

        <!-- Panel for Task Member Reports -->
        <panel title="Team Members Reports" canCollapse="true" collapseIf="false" colSpan="12">
          <field name="reportedTaskCount" title="Tasks Reported" x-dirty="false"
            readonly="true" colSpan="3"/>
          <field name="taskMemberReports" widget="list" colSpan="12" canNew="true"
            canEdit="true" form-view="task-member-report-form"
            onChange="action-task-member-report-group-onChange"/>
          <panel>
            <field name="totalWorkHours" colSpan="3" readonly="true"/>
          </panel>
        </panel>

        <panel colSpan="12" showFrame="false">
          <panel title="Extra charges" colSpan="6" showFrame="true">
            <field name="travelExpenses" colSpan="6" widget="checkbox"/>
            <field name="toolsUsage" colSpan="6" widget="checkbox"/>
          </panel>
          <panel title="Additional Services" colSpan="6" showFrame="true">
            <field name="dirtAllowance" colSpan="12" widget="checkbox" readonly="true"/>
          </panel>
          <panel title="Activity Details" colSpan="12" showTitle="false">
            <field name="material" colSpan="12" widget="textarea"/>
            <field name="comments" title="Comments" colSpan="12" widget="textarea"/>
          </panel>
        </panel>

        <!-- MGM Enclose sign-off panels into a global panel for hiding -->
        <panel name="signatureInfoPanel" showIf="!reportedAllTasks" colSpan="12"
          showFrame="false">
          <panel colSpan="12">
            <help css="alert-info">
              <![CDATA[
                The Sign-Off section will show once all project tasks have been reported
              ]]>
            </help>
          </panel>
        </panel>

        <panel name="signatureParentPanel" colSpan="12" showFrame="false"
          hideIf="!reportedAllTasks">
          <panel title="Sign-Off" showFrame="false" colSpan="12">
            <panel colSpan="12">
              <field name="taskDate" colSpan="4"/>
              <field widget="checkbox" name="customerNotAvailable" colSpan="3" hidden="true"/>
              <field widget="checkbox" name="customerNotAvailable" colSpan="5"
                title="Customer Not Available" onChange="action-customer-available-attrs"/>
            </panel>
          </panel>
          <panel colSpan="12">
            <panel colSpan="12">
              <field name="employee" title="Employee Name"/>
              <field name="customerName" title="Customer Name" hideIf="customerNotAvailable"/>

              <field name="employeeSignature" title="Employee Signature" widget="drawing"
                colSpan="6" x-stroke-width="1.5"/>
              <field name="customerSignature" title="Customer Signature" widget="drawing"
                colSpan="6" x-stroke-width="1.5" hideIf="customerNotAvailable"/>
              <field name="reportedAllTasks" hidden="true" x-dirty="false"/>
            </panel>
          </panel>
        </panel>
      </panel>
    </panel>
  </form>

  <!-- Define the form view for Task Member Report -->
  <form name="task-member-report-form" title="Team Member Report"
    onLoad="action-task-member-report-group-on-load" onNew="action-task-member-report-group-on-new"
    onSave="action-group-task-member-report-on-save"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <panel colSpan="12" canCollapse="true" collapseIf="false">
      <field name="task" title="Task" widget="Select"
        onSelect="action-validate-task-member-report-no-time-overlap"
        onChange="action-task-member-report-on-change-task,action-validate-task-member-report-no-time-overlap"
        required="true" colSpan="4"/>
      <field name="employee" title="Employee" readonly="true" colSpan="4" canView="false"/>
      <field name="dirtAllowance" widget="checkbox" colSpan="4"/>
      <field name="startTime" required="true"
        onChange="action-validate-task-member-report-no-time-overlap,action-task-report-on-change-time,action-task-member-report-validate-start-time-after-end-time"/>
      <field name="breakTimeMinutes" title="Break Time (minutes)"
        onChange="action-task-member-report-sync-minutes-to-hours,action-task-report-on-change-time"/>
      <field name="endTime" required="true"
        onChange="action-validate-task-member-report-no-time-overlap,action-task-report-on-change-time,action-task-member-report-validate-start-time-after-end-time"/>
      <field name="taskCategory" title="Task Category" readonly="true" canView="false"/>
      <field name="workHours"/>
      <field name="task.product" showIf="_reviewing" canView="false"/>
      <field name="breakTimeHours" hidden="true"/>
    </panel>
  </form>

  <form name="task-report-header-form" title="mgm report header"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <panel name="companyHeaderPanel" colSpan="12" showFrame="false">
      <static name="headerStatic" colSpan="12">
        <![CDATA[
        <div style="display: flex; align-items: flex-start; justify-content: space-between; padding: 20px 0; margin-bottom: 10px; font-family: sans-serif;">

          <div style="flex: 1; display: flex; flex-direction: column;">
            <img src="ws/public/app/logo" alt="Logo" style="width: 350px; height: auto;" />
          </div>

          <div style="flex: 1; text-align: center; padding-top: 40px;">
            <h1 style="margin: 0; font-size: 24px; font-weight: 500; color: #000; text-transform: uppercase; letter-spacing: 2px;">
              MGM Rapport
            </h1>
          </div>

          <div style="flex: 1;"></div>

        </div>
      ]]>
      </static>
    </panel>
  </form>

  <action-attrs name="action-customer-available-attrs">
    <attribute for="customerName" name="hidden" expr="customerNotAvailable"/>
    <attribute for="customerSignature" name="hidden" expr="customerNotAvailable"/>
  </action-attrs>

  <action-attrs name="action-task-member-report-attrs-task-domain">
    <attribute name="domain"
      expr="eval: &quot;self.project.id = ${__parent__?.project?.id ?: 0} AND (self.isTemplate = false OR self.isTemplate IS NULL)&quot;"
      for="task"/>
  </action-attrs>
  <action-attrs name="action-task-report-attrs-filter-projects">
    <attribute name="domain" for="project"
      expr="eval: __user__.group?.code == 'CUSTOM-PT' || __user__.group?.code == 'CUSTOM-TM' ?
    'self.projectStatus.isCompleted = false AND (self.membersUserSet[].id = ' + __user__.id + ' OR self.assignedTo.id = ' + __user__.id + ')' :
           'self.projectStatus.isCompleted = false'"/>
  </action-attrs>


  <action-validate
    name="action-task-member-report-validate-start-time-after-end-time">
    <error message="Start time must be before or at end time"
      if="startTime != null &amp;&amp; endTime != null &amp;&amp; startTime.isAfter(endTime)"
      action="action-task-member-report-reset-invalid-time"/>
  </action-validate>

  <action-validate name="action-task-report-validate-deleted-tmr-tsl-state">
    <error
      message="A timesheet line linked to a deleted task member report entry has already been invoiced and cannot be deleted. Please review your changes."
      if="tslDeleteWarningState == 'invoiced'" action="action-method-cancel-tmr-deletion"/>
    <error
      message="A timesheet line linked to a deleted task member report is already validated. Please invalidate the timesheet line before removing the entry."
      if="tslDeleteWarningState == 'validated'" action="action-method-cancel-tmr-deletion"/>
    <error
      message="A timesheet line linked to a deleted task member report is referenced in an invoicing project. Please remove it from the invoicing project before deleting this entry."
      if="tslDeleteWarningState == 'referenced_in_invoicing_project'"
      action="action-method-cancel-tmr-deletion"/>
    <alert
      message="Removing this task member report will also delete the associated timesheet line. Do you want to continue?"
      if="tslDeleteWarningState == 'deletable'" confirm-btn-title="Continue"
      cancel-btn-title="Cancel" action="action-method-cancel-tmr-deletion"/>
  </action-validate>

  <action-method name="action-task-report-method-preview">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="previewTaskReport"/>
  </action-method>

  <action-method name="action-task-report-validate">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="validateTaskReport"/>
  </action-method>

  <action-method name="action-task-report-set-flag">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="setReportedAllProjectTaskFlag"/>
  </action-method>

  <action-method name="action-task-report-method-updated-reported-task-count">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="updateReportedTaskCount"/>
  </action-method>

  <action-method name="action-task-member-report-method-filter-tasks">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="filterTasksForMemberReport"/>
  </action-method>

  <action-method name="action-method-task-report-filter-task-member-reports">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="filterTaskMemberReports"/>
  </action-method>

  <action-method name="action-validate-task-member-report-no-time-overlap">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="checkTimeOverlap"/>
  </action-method>

  <action-method name="action-task-report-check-deleted-tmr-tsl-state">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="checkDeletedTMRTimesheetLineState"/>
  </action-method>

  <action-method name="action-task-report-method-delete-tmr-timesheet-lines">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="deleteRemovedTMRTimesheetLines"/>
  </action-method>

  <!-- Action when project changes - autofill all related fields -->
  <action-record name="action-task-report-on-change-project"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <field name="customer" expr="eval: project?.clientPartner"/>
    <field name="location" expr="eval: project?.customerAddress"/>
    <field name="taskMemberReports" expr="eval: null"/>
  </action-record>

  <action-record name="action-task-member-report-on-change-task"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="employee" expr="eval: task?.assignedTo"/>
    <field name="taskCategory" expr="eval: task?.projectTaskCategory"/>
  </action-record>

  <action-record name="action-task-member-report-record-default-start-time"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="startTime" expr="eval: __datetime__"/>
  </action-record>

  <action-record name="action-task-member-report-reset-invalid-time"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="endTime" expr="eval: null"/>
    <field name="workHours" expr="eval: null"/>
  </action-record>

  <action-view name="action-task-report-dashlet"
    model="com.axelor.apps.businessproject.db.TaskReport" title="Task Reports">
    <view name="add-task-report-grid" type="grid"/>
    <view name="task-report-form" type="form"/>
    <view-param name="show-toolbar" value="true"/>
    <domain>
      self.project != null
      AND self.project.id = :_projectId
    </domain>
    <context name="_projectId" expr="eval: id"/>
    <context name="project" expr="eval: __this__"/>
  </action-view>

  <action-view name="member-task-report" title="Member Task Reports"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <view type="form" name="task-member-report-form"/>
    <context name="employee" expr="eval: project?.membersUserSet"/>
    <context name="project" expr="eval: __parent__.project"/>
  </action-view>
  <action-view name="action-task-report-new" title="New Task Report"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <view type="form" name="task-report-form"/>
    <context name="project" expr="eval: _self"/>
    <context name="__new__" expr="true"/>
  </action-view>

  <action-record name="action-task-report-on-change-time"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="workHours"
      expr="eval:
      (startTime != null &amp;&amp; endTime != null)
      ? (
          (
            java.time.Duration.between(startTime, endTime).toMinutes() / 60.0
          ) - (breakTimeHours ?: 0)
        )
      : 0"/>
  </action-record>

  <action-record name="action-update-total-work-hours"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <field name="totalWorkHours"
      expr="eval: (taskMemberReports != null) ? taskMemberReports.stream().filter(r -> r.workHours != null).map(r -> r.workHours)
          .reduce(java.math.BigDecimal.ZERO, java.math.BigDecimal::add) : 0"/>
  </action-record>

  <action-record name="mgm-action-update-total-work-hours"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <field name="totalWorkHours"
      expr="eval: (taskMemberReports != null) ? taskMemberReports.stream().filter(r -> r != null &amp;&amp; r.workHours != null).map(r -> r.workHours).reduce(java.math.BigDecimal.ZERO, java.math.BigDecimal::add) : 0"/>
  </action-record>

  <action-record name="mgm-action-sync-dirt-allowance-status"
    model="com.axelor.apps.businessproject.db.TaskReport">
    <field name="dirtAllowance"
      expr="eval: (taskMemberReports != null) ? taskMemberReports.stream().anyMatch(r -> r != null &amp;&amp; Boolean.TRUE.equals(r.dirtAllowance)) : false"/>
  </action-record>

  <action-record name="action-task-member-report-sync-minutes-to-hours"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="breakTimeHours"
      expr="eval: breakTimeMinutes != null ? (breakTimeMinutes / 60.0) : null"/>
  </action-record>

  <action-record name="action-task-member-report-sync-hours-to-minutes"
    model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <field name="breakTimeMinutes"
      expr="eval: breakTimeHours != null ? Math.round(breakTimeHours * 60) : null"/>
  </action-record>

  <action-group name="action-task-report-group-on-save">
    <action name="mgm-action-validate-warn-billing-item-edited-after-project-confirmation"/>
    <action name="action-task-report-check-deleted-tmr-tsl-state"/>
    <action name="action-task-report-validate-deleted-tmr-tsl-state"/>
    <action name="action-task-report-method-delete-tmr-timesheet-lines"/>
    <action name="mgm-action-update-total-work-hours"/>
    <action name="mgm-action-sync-dirt-allowance-status"/>
    <action name="action-task-report-validate"/>
    <action name="action-task-report-set-flag"/>
    <action name="action-task-report-method-updated-reported-task-count"/>
  </action-group>

  <action-group name="action-task-report-group-on-load">
    <action name="action-task-report-attrs-filter-projects"/>
    <action name="action-task-report-set-flag"/>
    <action name="action-task-report-method-updated-reported-task-count"/>
  </action-group>

  <action-group name="action-task-member-report-group-on-new">
    <action name="action-task-member-report-method-filter-tasks"/>
    <action name="action-task-member-report-record-default-start-time"/>
  </action-group>

  <action-group name="action-task-member-report-group-on-load">
    <action name="action-task-member-report-method-filter-tasks" if="!_reviewing"/>
    <action name="action-task-member-report-sync-hours-to-minutes" if="!_reviewing"/>
  </action-group>

  <action-group name="action-task-member-report-group-onChange">
    <action name="mgm-action-validate-warn-billing-item-edited-after-project-confirmation"/>
    <action name="action-task-report-check-deleted-tmr-tsl-state"/>
    <action name="action-task-report-validate-deleted-tmr-tsl-state"/>
    <action name="action-task-report-method-delete-tmr-timesheet-lines"/>
    <action name="save"/>
    <action name="mgm-action-update-total-work-hours"/>
    <action name="mgm-action-sync-dirt-allowance-status"/>
    <action name="action-task-report-method-updated-reported-task-count"/>
    <action name="action-task-report-set-flag"/>
  </action-group>

  <action-group name="action-group-task-member-report-on-save">
    <action name="action-task-member-report-validate-start-time-after-end-time"/>
    <action name="action-task-report-on-change-time"/>
  </action-group>

  <action-method name="action-method-cancel-tmr-deletion">
    <call class="com.axelor.apps.businessproject.web.TaskReportController"
      method="cancelDelete"/>
  </action-method>

  <action-view name="mgm-action-task-member-report-review"
    title="Task member reports review" model="com.axelor.apps.businessproject.db.TaskMemberReport">
    <view type="grid" name="task-member-report-review-grid"/>
    <view type="form" name="task-member-report-form"/>
    <domain>self.task.project.id = :_projectId</domain>
    <context name="_projectId" expr="eval: id"/>
    <context name="_reviewing" expr="eval: true"/>
  </action-view>

</object-views>