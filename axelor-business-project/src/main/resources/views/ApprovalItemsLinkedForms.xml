<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.4.xsd">

  <!-- Timesheet Line -->
  <form name="mgm-approval-item-timesheet-line-form" title="Timesheet Line"
    model="com.axelor.apps.hr.db.TimesheetLine" width="large"
    onLoad="action-group-timesheet-line-approval-item-on-load"
    onSave="action-group-timesheet-line-approval-item-on-save" canNew="false" canAttach="false"
    canArchive="false" onDelete="mgm-action-method-refresh-tab">
    <toolbar>
      <button name="projectFilesBtn" title="Project Files" showIf="project &amp;&amp; id"
        icon="fa-paperclip" onClick="action-method-project-find-project-files"/>
    </toolbar>
    <panel name="mainPanel" colSpan="12">
      <panel name="detailsPanel" colSpan="9">
        <panel name="headPanel" colSpan="12" hidden="true">
          <field name="isValidated" canView="false"/>
        </panel>
        <field name="project" canView="true" readonly="true" form-view="business-project-form"
          grid-view="business-project-grid"/>
        <field name="projectTask" canView="true" readonly="true"
          form-view="business-project-task-form" grid-view="business-project-task-grid"/>
        <field if="__config__.app.getApp('base')?.enableSiteManagementForProject" name="site"
          onSelect="action-timesheet-line-attrs-set-site-domain" form-view="site-form"
          grid-view="site-grid"/>
        <field name="startTime" colSpan="6"
          onChange="action-timesheet-line-validate-and-calculate" required="true"/>
        <field name="endTime" colSpan="6"
          onChange="action-timesheet-line-validate-and-calculate"/>
        <field if="__config__.app.getApp('timesheet')?.enableActivity" name="product"
          widget="SuggestBox" canEdit="false"
          onSelect="action-hr-timesheet-line-attrs-domain-product" requiredIf="toInvoice"
          form-view="product-activity-form" grid-view="product-activity-grid"/>
        <field name="breakTimeMinutes" title="Break Time (minutes)"
          onChange="action-timesheet-line-sync-minutes-to-hours,action-timesheet-line-validate-and-calculate"/>
        <field name="duration" colSpan="3"
          onChange="action-timesheet-line-method-set-stored-duration" min="0.01"/>
        <label name="durationLabel" colSpan="3"/>
        <field name="durationForCustomer" hidden="true" colSpan="3"/>
        <label if="__config__.app.isApp('business-project')"
          if-module="axelor-business-project" name="durationLabel" colSpan="1" hidden="true"/>
        <field name="hoursDuration" hidden="true"/>
        <field name="date" hidden="true"/>
        <field name="timer" showIf="timer" form-view="ts-timer-form" grid-view="ts-timer-grid"/>
        <field
          if="__config__.app.isApp('business-project') &amp;&amp; __config__.app.getApp('business-project').automaticInvoicing"
          if-module="axelor-business-project" name="toInvoice" readonly="true"/>
        <field
          if="__config__.app.isApp('business-project') &amp;&amp; !__config__.app.getApp('business-project').automaticInvoicing"
          if-module="axelor-business-project" name="toInvoice"/>
        <field name="comments"/>
        <field if="__config__.app.getApp('timesheet')?.getTimesheetEditor()"
          name="enableEditor"/>
        <field name="employee" hidden="true" canNew="false" canView="false" canEdit="false"
          form-view="employee-form" grid-view="employee-grid"/>
        <field name="breakTime" hidden="true"/>
      </panel>
      <panel name="actionsPanel" colSpan="3" itemSpan="12">
        <button showIf="!isValidated" name="validateLineButton" title="Validate"
          onClick="action-timesheet-line-validate, mgm-action-method-refresh-tab" css="btn-success"
          icon="fa-check"/>
        <button showIf="isValidated" name="cancelLineButton" title="Cancel"
          onClick="action-timesheet-line-cancel, mgm-action-method-refresh-tab" css="btn-danger"
          icon="fa-times"/>
      </panel>
    </panel>
    <panel name="timesheetPanel" colSpan="12" title="Related Timesheet">
      <field name="timesheet" canEdit="false" form-view="timesheet-form"
        grid-view="timesheet-grid" canView="false"/>
      <field name="timesheet.company" canView="false"/>
      <field name="timesheet.employee" canView="false"/>
      <field if="__config__.app.getApp('timesheet')?.needValidation"
        name="timesheet.statusSelect"/>
    </panel>
  </form>


  <!-- Expenses -->
  <form name="mgm-approval-item-expense-form" title="Project Expenses"
    model="com.axelor.apps.hr.db.Expense" width="large"
    onSave="action-expense-method-validate-and-compute, mgm-action-method-refresh-tab"
    canNew="false" onNew="mgm-action-project-expense-group-form-onNew"
    canDelete="ventilated == false" canAttach="false" canArchive="false"
    onDelete="mgm-action-method-refresh-tab">
    <menubar>
      <menu name="expenseReportsMenu" title="Reports" icon="fa-files-o">
        <item name="printAll" title="Print report and files"
          action="save,action-expense-method-print-report-and-proof-file"/>
      </menu>
    </menubar>
    <panel name="mainPanel">
      <panel name="statusPanel" colSpan="9">
        <field name="statusSelect" showTitle="false" colSpan="12" widget="NavSelect"/>
        <field name="expenseSeq" showTitle="false" colSpan="8">
          <viewer depends="expenseSeq"><![CDATA[

				<>
					<h3>
						<span>{_t('Expense')} </span>
					</h3>
				</>

        ]]></viewer>
        </field>
        <field name="ventilated" showTitle="false" readonly="true" showIf="ventilated"
          colSpan="4">
          <viewer><![CDATA[
	<><Badge bg="danger">{_t('Ventilated')}</Badge></>
        ]]></viewer>
        </field>
        <panel name="generalInfoPanel" colSpan="12">
          <field name="typeSelect" readonly="true"/>
          <field name="categorySelect" readonly="true"/>
          <field name="company" canEdit="false" required="true" form-view="company-form"
            readonly="true" grid-view="company-grid"/>
          <field name="employee" canNew="false" canView="false" required="true"
            readonly="true" form-view="employee-form" grid-view="employee-grid"
            requiredIf="categorySelect == 1" hideIf="categorySelect == 2"
            domain="self.user IN (SELECT m FROM Project p JOIN p.membersUserSet m WHERE p = :project) OR self.user IN (SELECT p.assignedTo FROM Project p WHERE p = :project)"/>
          <field name="period" canView="false" canEdit="false" readonly="true"
            onSelect="action-expense-attrs-domain-period" form-view="period-form"
            grid-view="period-grid"/>
          <field name="project" form-view="business-project-form" grid-view="project-grid"
            readonly="true" canView="true"/>
          <field name="personalExpenseAmount" hidden="true"/>
          <field name="advanceAmount" hidden="true"/>
        </panel>
      </panel>
      <panel name="sidePanel" colSpan="3" itemSpan="12">
        <panel name="actionsPanel" itemSpan="12">
          <button name="sendExpensesBtn" title="Send Expenses" hidden="true"
            hideIf="statusSelect > 1"
            onClick="action-expense-group-send, mgm-action-method-refresh-tab"/>
          <button
            if="!(['CUSTOM-ACCOUNTANT','CUSTOM-PT','CUSTOM-TM','CUSTOM-PM'].any(g -> __user__.group.code.contains(g)))"
            name="ventilateBtn" title="Ventilate" hidden="true"
            onClick="save,action-expense-method-ventilate, mgm-action-method-refresh-tab"/>
          <button
            if="!(['CUSTOM-ACCOUNTANT','CUSTOM-PT','CUSTOM-PM'].any(g -> __user__.group.code.contains(g)))"
            name="validateBtn" title="Validate"
            onClick="action-expense-group-validate, mgm-action-method-refresh-tab"/>
          <button
            if="!(['CUSTOM-ACCOUNTANT','CUSTOM-PT','CUSTOM-TM','CUSTOM-PM'].any(g -> __user__.group.code.contains(g)))"
            name="refuseBtn" title="Refuse"
            onClick="action-expense-group-refuse, mgm-action-method-refresh-tab"/>
          <button
            if="!(['CUSTOM-ACCOUNTANT','CUSTOM-PT','CUSTOM-PM'].any(g -> __user__.group.code.contains(g)))"
            name="cancelBtn" title="Cancel" css="btn-danger" icon="fa-times-circle"
            onClick="action-expense-group-cancel, mgm-action-method-refresh-tab"/>
          <button name="draftBtn" title="Return to draft status" showIf="statusSelect > 4 "
            onClick="action-expense-method-draft, mgm-action-method-refresh-tab"/>
          <button name="addPaymentBtn" title="Register payment"
            showIf="ventilated &amp;&amp; statusSelect == 3  &amp;&amp; (paymentStatusSelect == 0 || paymentStatusSelect == 2) &amp;&amp; companyCbSelect != 2"
            onClick="save,action-expense-add-payment-form, mgm-action-method-refresh-tab"/>
          <button name="cancelPaymentBtn" title="Cancel payment"
            showIf="(paymentStatusSelect == 1 || paymentStatusSelect == 3)"
            onClick="save,action-expense-method-cancel-payment, mgm-action-method-refresh-tab"/>
        </panel>
        <panel name="inTaxTotalPanel" readonly="true">
          <field name="inTaxTotal" showTitle="false" colSpan="12" x-currency="currency.symbol">
            <viewer
              depends="exTaxTotal,taxTotal,inTaxTotal,$totalToRefund,totalAmountToInvoice"><![CDATA[
                <>
                  <Box as="dl" d="grid" gridTemplateColumns="1fr 1fr" textAlign="end">
                    <Box as="dt" m={0} px={3} py={1} fontWeight="normal">{_t('Total W.T.')}</Box>
                    <Box as="dd" m={0} px={3} py={1}>{$fmt('exTaxTotal')}</Box>
                    <Box as="dt" m={0} px={3} py={1} fontWeight="normal">{_t('Total tax')}</Box>
                    <Box as="dd" m={0} px={3} py={1}>{$fmt('taxTotal')}</Box>
                    <Box as="dt" m={0} px={3} py={1} borderTop fontWeight="bold">{_t('Total to Refund')}</Box>
                    <Box as="dd" m={0} px={3} py={1} borderTop fontWeight="bold">{$fmt('inTaxTotal')}</Box>
                    <Box as="dt" m={0} px={3} py={1} color="info" borderTop>{_t('Total to Invoice')}</Box>
                    <Box as="dd" m={0} px={3} py={1} color="info" fontWeight="bold" borderTop>{$fmt('totalAmountToInvoice')}</Box>
                  </Box>
                </>
              ]]></viewer>
          </field>
          <field name="exTaxTotal" hidden="true" x-currency="currency.symbol"/>
          <field name="inTaxTotal" hidden="true" x-currency="currency.symbol"/>
          <field name="taxTotal" hidden="true" x-currency="currency.symbol"/>
        </panel>
      </panel>
    </panel>
    <panel-tabs name="mainPanelTab">
      <panel name="employeeExpensePanelMainPanel" title="General expenses"
        showIf="categorySelect == 1">
        <panel-related name="generalExpenseLineListPanel" title="General expenses"
          colSpan="12" field="generalExpenseLineList" form-view="mgm-expense-line-form"
          grid-view="mgm-expense-line-grid"/>
      </panel>
      <panel name="feeExpensePanelMainPanel" title="Project fees" showIf="categorySelect == 2">
        <panel-related name="feeExpenseLineListPanel" title="Project fees"
          colSpan="12" field="generalExpenseLineList" form-view="mgm-fees-expense-line-form"
          grid-view="mgm-fees-expense-line-grid"/>
      </panel>
    </panel-tabs>
    <panel name="followupPanel" title="Follow-up" showIf="sentDateTime" colSpan="12"
      canCollapse="true">
      <field name="sentDateTime" colSpan="4"/>
      <field name="validatedBy" hidden="true" showIf="validatedBy" colSpan="4" canEdit="false"
        form-view="user-form" grid-view="user-grid"/>
      <field name="validationDateTime" hidden="true" showIf="validationDateTime" colSpan="4"/>
      <field name="refusedBy" hidden="true" showIf="refusedBy" colSpan="4" canEdit="false"
        form-view="user-form" grid-view="user-grid"/>
      <field name="refusalDateTime" hidden="true" showIf="refusalDateTime" colSpan="4"/>
      <field name="groundForRefusal" hidden="true" readonly="true"
        showIf="statusSelect == 5 || groundForRefusal != null" colSpan="12"/>
    </panel>
  </form>

  <action-method name="mgm-action-method-refresh-app">
    <call class="com.axelor.apps.businessproject.web.ApprovalItemController"
      method="refreshApp"/>
  </action-method>

  <action-method name="mgm-action-method-refresh-tab">
    <call class="com.axelor.apps.businessproject.web.ApprovalItemController"
      method="refreshTab"/>
  </action-method>

  <action-group name="action-group-timesheet-line-approval-item-on-save">
    <action name="action-timesheet-line-group-project-task-form-on-save"/>
    <action name="action-timesheet-line-method-set-stored-duration"/>
    <action name="action-timesheet-line-group-on-save"/>
    <action name="mgm-action-method-refresh-tab"/>
  </action-group>

  <action-group name="action-group-timesheet-line-approval-item-on-load">
    <action name="action-timesheet-line-attrs-set-duration-label"/>
    <action name="action-timesheet-line-attrs-title-project"/>
    <action name="action-timesheet-line-sync-hours-to-minutes"/>
  </action-group>

</object-views>