<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.4.xsd">

  <action-view name="technician.manager.home.action"
    title="Technician Manager Dashboard">
    <view type="dashboard" name="technician.manager.dashboard"/>
  </action-view>

  <dashboard name="technician.manager.dashboard" title="Technician Manager Dashboard">

    <dashlet name="technician.manager.chart.approval.items.overview"
      action="action.technician.manager.chart.approval.items.overview" colSpan="12" height="250"/>

    <dashlet name="technician.manager.approval.items"
      action="action.technician.manager.view.approval.items" colSpan="12" height="450"
      canSearch="true"/>

    <dashlet name="technician.manager.my.ongoing.projects"
      action="action.view.technician.manager.my.ongoing.projects" colSpan="6" height="400"
      canSearch="true"/>

    <dashlet name="technician.manager.my.ongoing.tasks"
      action="action.view.my.ongoing.tasks" colSpan="6" height="400" canSearch="true"/>

  </dashboard>


  <chart name="chart-technician-manager-approval-items-overview"
    title="Approval Items Overview">
    <dataset type="rpc">
      com.axelor.apps.businessproject.web.ApprovalItemController:buildApprovalItemChartDataSet
    </dataset>
    <category key="itemType" type="text" title="Item Type"/>
    <series key="count" type="donut" title="Number of Items"/>
    <config name="colors" value="#1E88E5,#43A047"/>
  </chart>

  <action-view name="action.technician.manager.chart.approval.items.overview"
    title="Approval Items Overview">
    <view type="chart" name="chart-technician-manager-approval-items-overview"/>
  </action-view>

  <action-view name="action.technician.manager.view.approval.items"
    title="Approvals items" model="com.axelor.apps.businessproject.db.ApprovalItem">
    <view type="grid" name="approval-item-grid"/>
    <view type="form" name="approval-item-form"/>
    <view-param name="popup" value="true"/>
    <domain><![CDATA[
      self.project.assignedTo = :__user__ OR :__user__ MEMBER OF self.project.membersUserSet
    ]]></domain>
  </action-view>

  <action-view name="action.view.technician.manager.my.ongoing.projects"
    title="My Ongoing Projects" model="com.axelor.apps.project.db.Project">
    <view type="grid" name="business-project-grid"/>
    <view type="form" name="business-project-form"/>
    <domain><![CDATA[
      (self.assignedTo = :__user__ OR :__user__ MEMBER OF self.membersUserSet)
      AND self.projectStatus.isCompleted = false
    ]]></domain>
  </action-view>

</object-views>