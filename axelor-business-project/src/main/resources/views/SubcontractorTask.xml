<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.4.xsd">

  <grid name="mgm-subcontractor-task-grid" title="Qualification"
    model="com.axelor.apps.businessproject.db.SubcontractorTask">
    <field name="employee"/>
    <field name="product"/>
    <field name="timeSpentMinutes"/>
    <field name="timeSpent" aggregate="sum"/>
    <field name="comments"/>
  </grid>

  <grid name="mgm-subcontractor-project-subcontractor-task-grid" title="Qualification"
    model="com.axelor.apps.businessproject.db.SubcontractorTask">
    <field name="product"/>
    <field name="timeSpentMinutes"/>
    <field name="timeSpent" aggregate="sum"/>
    <field name="comments"/>
  </grid>

  <form name="mgm-subcontractor-task-form" title="Qualification"
    onNew="mgm-action-method-business-project-set-subcontractor-task-defaults, mgm-action-method-set-subcontractor-employee-attrs"
    onLoad="mgm-action-method-set-subcontractor-employee-attrs"
    model="com.axelor.apps.businessproject.db.SubcontractorTask"
    onSave="mgm-action-validate-warn-billing-item-edited-after-project-confirmation, mgm-action-method-sync-time-spent">
    <panel name="mainPanel" title="Service Info">
      <field name="product" required="true"
        domain="self.isActivity = true AND self.dtype = 'Product'"/>
      <field name="timeSpentMinutes"/>
      <field name="employee" readonly="false"/>
      <field name="project" hidden="true"/>
      <field name="subContractor" hidden="true"/>
    </panel>
    <panel name="commentsPanel" title="Comments">
      <field name="comments" showTitle="false" colSpan="12"/>
    </panel>
    <panel name="hiddenFields" title="Hidden fields" hidden="true">
      <field name="timeSpent"/>
    </panel>
  </form>

  <form name="mgm-subcontractor-project-subcontractor-task-form" title="Qualification"
    onNew="mgm-action-method-business-project-set-subcontractor-task-defaults"
    model="com.axelor.apps.businessproject.db.SubcontractorTask"
    onSave="mgm-action-validate-warn-billing-item-edited-after-project-confirmation, mgm-action-method-sync-time-spent">
    <panel name="mainPanel" title="Service Info">
      <field name="product" required="true"
        domain="self.isActivity = true AND self.dtype = 'Product'"/>
      <field name="timeSpentMinutes"/>
      <field name="project" hidden="true"/>
      <field name="subcontractor" hidden="true"/>
    </panel>
    <panel name="commentsPanel" title="Comments">
      <field name="comments" showTitle="false" colSpan="12"/>
    </panel>
    <panel name="hiddenFields" title="Hidden fields" hidden="true">
      <field name="timeSpent"/>
    </panel>
  </form>

  <action-method
    name="mgm-action-method-business-project-set-subcontractor-task-defaults">
    <call class="com.axelor.apps.businessproject.web.SubcontractorTaskController"
      method="setSubcontractorTaskDefaults"/>
  </action-method>

  <action-method name="mgm-action-method-set-subcontractor-employee-attrs">
    <call class="com.axelor.apps.businessproject.web.SubcontractorTaskController"
      method="setSubcontractorTaskEmployeeFilter"/>
  </action-method>

  <action-view
    name="mgm-action-subcontractor-business-project-subcontractor-task-dashlet"
    model="com.axelor.apps.businessproject.db.SubcontractorTask" title="Qualification">
    <view type="grid" name="mgm-subcontractor-project-subcontractor-task-grid"/>
    <view type="form" name="mgm-subcontractor-project-subcontractor-task-form"/>
    <view-param name="popup" value="true"/>
    <view-param name="show-toolbar" value="true"/>
    <domain>
      self.project.id = :_projectId
    </domain>
    <context name="_projectId" expr="eval: __this__.id"/>
  </action-view>

  <action-view name="mgm-action-business-project-subcontractor-task-dashlet"
    model="com.axelor.apps.businessproject.db.SubcontractorTask" title="Qualification">
    <view type="grid" name="mgm-subcontractor-task-grid"/>
    <view type="form" name="mgm-subcontractor-task-form"/>
    <view-param name="popup" value="true"/>
    <view-param name="show-toolbar" value="true"/>
    <domain>
      self.project.id = :_projectId
    </domain>
    <context name="_projectId" expr="eval: __this__.id"/>
  </action-view>

  <action-method name="mgm-action-method-sync-time-spent">
    <call class="com.axelor.apps.businessproject.web.SubcontractorTaskController"
      method="syncTimeSpent"/>
  </action-method>

</object-views>