<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.4.xsd">

  <grid name="extra-expense-line-grid" title="Extra Expense Lines" canEdit="true"
    groupBy="expenseDate" model="com.axelor.apps.businessproject.db.ExtraExpenseLine">
    <field name="extraExpenseLineTypeSelect"/>
    <field name="expenseProduct" form-view="product-form" grid-view="product-grid"/>
    <field name="expenseDate"/>
    <field name="price"/>
    <field name="quantity"/>
    <field name="totalAmount" aggregate="sum"/>
    <field name="toInvoice"/>
    <field name="project" hidden="true"/>
    <field name="comments"/>
  </grid>

  <grid name="mgm-extra-expense-line-project-grid" title="Extra Expense Lines" canEdit="true"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine">
    <field name="expenseProduct" form-view="product-form" grid-view="product-grid"/>
    <field name="expenseDate"/>
    <field name="price"/>
    <field name="quantity"/>
    <field name="totalAmount" aggregate="sum"/>
    <field name="extraExpenseLineTypeSelect" hidden="true"/>
  </grid>

  <form name="extra-expense-line-form" title="Extra Expense Line"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine" width="large">
    <panel name="Extra Expense Details">
      <field name="expenseProduct" form-view="product-expense-form"
        grid-view="product-expense-grid"/>
      <field name="project" form-view="project-form" grid-view="project-grid" readonly="true"/>
      <field name="price" colSpan="4" readonly="true"/>
      <field name="quantity" colSpan="4" canEdit="true" canNew="true"
        onChange="compute-total-amount"/>
      <field name="totalAmount" colSpan="4" readonly="true"/>
      <field name="toInvoice"/>
    </panel>
    <panel name="comments">
      <field name="comments" showTitle="false" colSpan="12"/>
    </panel>
  </form>

  <form name="mgm-extra-expense-line-business-project-form" title="Extra Expense Line"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine" width="large"
    onNew="mgm-action-method-extra-expense-set-defaults-on-new"
    onSave="mgm-action-validate-warn-billing-item-edited-after-project-confirmation">
    <panel showFrame="false">
      <field name="expenseProduct" form-view="product-expense-form"
        grid-view="product-expense-grid"
        domain="self.expense = true AND self.dtype = 'Product' AND self.code IN ('25KM','11KM','TOOLUSAGE')"
        onChange="mgm-action-group-extra-expense-product-on-change"/>
      <field name="quantity" canEdit="true" canNew="true" onChange="compute-total-amount"/>
      <field name="price" readonly="true"/>
      <field name="totalAmount" readonly="true"/>
      <field name="toInvoice"/>
      <field name="project" form-view="business-project-form"
        grid-view="business-project-grid" readonly="true" canView="false"/>
      <field name="extraExpenseLineTypeSelect" readonly="true" hidden="true"/>
    </panel>
    <panel name="comments">
      <field name="comments" showTitle="false" colSpan="12"/>
    </panel>
  </form>

  <action-method name="mgm-action-method-extra-expense-set-defaults-on-new">
    <call class="com.axelor.apps.businessproject.web.ExtraExpenseLineController"
      method="setExtraExpenseLineDefaults"/>
  </action-method>


  <action-view name="extra-expense-form-view-action"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine"
    title="Extra Expense Form View Action">
    <view type="form" name="extra-expense-line-form"/>
    <view type="grid" name="extra-expense-line-grid"/>
    <view-param name="popup" value="true"/>
    <view-param name="popup-save" value="true"/>
    <view-param name="show-toolbar" value="false"/>
  </action-view>

  <action-group name="mgm-action-group-extra-expense-product-on-change">
    <action name="mgm-action-method-extra-expense-line-set-type-select"/>
    <action name="mgm-action-record-extra-expense-line-set-price"/>
  </action-group>

  <action-method name="mgm-action-method-extra-expense-line-set-type-select">
    <call class="com.axelor.apps.businessproject.web.ExtraExpenseLineController"
      method="setExtraExpenseLineTypeSelect"/>
  </action-method>

  <action-record name="mgm-action-record-extra-expense-line-set-price"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine">
    <field name="price"
      expr="eval: (expenseProduct != null &amp;&amp; expenseProduct.salePrice != null) ? expenseProduct.salePrice : java.math.BigDecimal.ZERO"/>
  </action-record>

  <action-record name="compute-total-amount"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine">
    <field name="totalAmount"
      expr="eval: (price != null &amp;&amp; quantity != null) ? price.multiply(quantity) : java.math.BigDecimal.ZERO"/>
  </action-record>

  <action-view name="mgm-action-project-extra-expense-line-dashlet"
    model="com.axelor.apps.businessproject.db.ExtraExpenseLine" title="Project extra expense">
    <view type="grid" name="mgm-extra-expense-line-project-grid"/>
    <view type="form" name="mgm-extra-expense-line-business-project-form"/>
    <view-param name="popup" value="true"/>
    <view-param name="show-toolbar" value="true"/>
    <domain>
      self.project.id = :_projectId
    </domain>
    <context name="_projectId" expr="eval: __this__.id"/>
  </action-view>

</object-views>