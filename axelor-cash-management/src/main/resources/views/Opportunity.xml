<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_8.1.xsd">

  <form id="cash-management-opportunity-form" name="opportunity-form" title="Opportunity"
    model="com.axelor.apps.crm.db.Opportunity" extension="true">
    <extend target="/">
      <attribute name="onNew" value="cash-management-action-opportunity-group-new"/>
    </extend>
    <extend target="//field[@name='company']">
      <attribute name="onChange" value="action-opportunity-record-set-bank-details"/>
    </extend>
  </form>

  <action-group name="cash-management-action-opportunity-group-new">
    <action name="action-opportunity-group-new"/>
    <action name="action-opportunity-record-set-bank-details"/>
  </action-group>

  <action-record name="action-opportunity-record-set-bank-details"
    model="com.axelor.apps.crm.db.Opportunity">
    <field name="bankDetails" expr="eval: company?.defaultBankDetails"
      if="__config__.app.getApp('base')?.getManageMultiBanks()"/>
  </action-record>

</object-views>
