<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_7.2.xsd">

  <form id="business-production-business-project-form" name="business-project-form"
    title="Business project" model="com.axelor.apps.project.db.Project" extension="true">

    <extend target="//panel-related[@name='projectSaleOrderLineEditableTreePanel']">
      <replace>
        <panel-related name="projectSaleOrderLineEditableTreePanel"
          field="saleOrderLineList" widget="tree-grid" canNew="false" canRemove="false"
          title="Details Lines (Tree)" orderBy="sequence" form-view="sale-order-line-form"
          x-tree-field-title="Add a new sale order line"
          summary-view="business-production-sale-order-line-summary-project-form"
          grid-view="business-production-sale-order-line-editable-grid"
          x-tree-field="subSaleOrderLineList" colSpan="12"
          onChange="action-project-method-sale-order-line-list-onchange"/>
      </replace>
    </extend>
  </form>

  <action-method name="action-project-method-sale-order-line-list-onchange">
    <call class="com.axelor.apps.businessproduction.web.ProjectBusinessProductionController"
      method="solListOnChange"/>
  </action-method>

</object-views>